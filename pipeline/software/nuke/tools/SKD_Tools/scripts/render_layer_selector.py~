import nuke
from PySide2 import QtWidgets, QtCore, QtGui  # Use PyQt5 or PySide instead if your Nuke version requires it.
import os
import random
import time

class SimpleWindow(QtWidgets.QWidget):
    def __init__(self):
        super(SimpleWindow, self).__init__()

        # Set up the window
        self.setWindowTitle("L&D Import Render Layers")
        self.setGeometry(100, 100, 800, 600)

        # Create a label for the title
        self.title_label = QtWidgets.QLabel("L&D Import Render Layers", self)
        self.title_label.setAlignment(QtCore.Qt.AlignCenter)

        # Create a dropdown menu
        self.dropdown = QtWidgets.QComboBox(self)
        self.dropdown.addItems(["shot1", "shot2", "shot3", "shot4", "shot5", "shot6"])
        self.dropdown.setCurrentIndex(2)  # Set default to shot3
        self.dropdown.currentTextChanged.connect(self.update_images)

        # Wrap the dropdown in a horizontal layout for alignment
        dropdown_layout = QtWidgets.QHBoxLayout()
       # dropdown_layout.addStretch()
        dropdown_layout.addWidget(self.dropdown)
        dropdown_layout.addStretch()

        # Create a list widget for displaying thumbnails
        self.thumbnail_list = QtWidgets.QListWidget(self)
        self.thumbnail_list.setViewMode(QtWidgets.QListWidget.IconMode)
        self.thumbnail_list.setIconSize(QtCore.QSize(150, 150))
        self.thumbnail_list.setResizeMode(QtWidgets.QListWidget.Adjust)
        self.thumbnail_list.setSelectionMode(QtWidgets.QAbstractItemView.ExtendedSelection)

        # Create the buttons
        self.import_button = QtWidgets.QPushButton("Import Layers", self)
        self.import_button.clicked.connect(self.import_layers)

        self.cancel_button = QtWidgets.QPushButton("Cancel", self)
        self.cancel_button.clicked.connect(self.close)

        # Button layout
        button_layout = QtWidgets.QHBoxLayout()
        button_layout.addStretch()
        button_layout.addWidget(self.import_button)
        button_layout.addWidget(self.cancel_button)
        #button_layout.addStretch()

        # Main layout
        main_layout = QtWidgets.QVBoxLayout()
        main_layout.addWidget(self.title_label)
        main_layout.addLayout(dropdown_layout)  # Add the dropdown layout
        main_layout.addWidget(self.thumbnail_list)
        main_layout.addLayout(button_layout)
        self.setLayout(main_layout)

        # Update images for the default selection
        self.update_images(self.dropdown.currentText())

    def update_images(self, selected_item):
        # Clear the current thumbnails
        self.thumbnail_list.clear()

        base_path = r"C:\Users\SpencerB\Desktop\dev\example_folder"
        shot_path = os.path.join(base_path, selected_item.capitalize())

        if os.path.exists(shot_path):
            for folder_name in os.listdir(shot_path):
                folder_path = os.path.join(shot_path, folder_name, "images")
                if os.path.isdir(folder_path):
                    images = [f for f in os.listdir(folder_path) if f.lower().endswith((".png", ".jpg", ".jpeg", ".exr"))]
                    if images:
                        random_image = random.choice(images)
                        image_path = os.path.join(folder_path, random_image)

                        # Create a list widget item with the image and folder name
                        item = QtWidgets.QListWidgetItem()
                        pixmap = QtGui.QPixmap(image_path)
                        scaled_pixmap = pixmap.scaled(150, 150, QtCore.Qt.KeepAspectRatio, QtCore.Qt.SmoothTransformation)
                        item.setIcon(QtGui.QIcon(scaled_pixmap))

                        # Get folder creation date
                        creation_time = os.path.getctime(folder_path)
                        creation_date = time.strftime("%m-%d-%Y", time.localtime(creation_time))

                        # Set text with folder name and creation date
                        item.setText(f"{folder_name}\n{creation_date}")
                        item.setTextAlignment(QtCore.Qt.AlignCenter)
                        self.thumbnail_list.addItem(item)

    def import_layers(self):
        selected_items = self.thumbnail_list.selectedItems()
        if not selected_items:
            QtWidgets.QMessageBox.warning(self, "No Selection", "Please select at least one folder to import.")
            return

        for item in selected_items:
            folder_name = item.text().split("\n")[0]
            base_path = r"C:\Users\SpencerB\Desktop\dev\example_folder"
            folder_path = os.path.join(base_path, self.dropdown.currentText().capitalize(), folder_name, "images")

            if os.path.exists(folder_path):
                sequence_path = os.path.join(folder_path, "%04d.exr")  # Assuming EXR sequences with frame numbers
                if os.path.exists(sequence_path.replace("%04d", "0001")):  # Check if the first frame exists
                    nuke.createNode("Read", f"file {{{sequence_path}}}")
                else:
                    QtWidgets.QMessageBox.warning(self, "Missing Sequence", f"No valid sequence found in {folder_path}")
            else:
                QtWidgets.QMessageBox.warning(self, "Missing Folder", f"The folder '{folder_name}' does not exist.")

# Function to show the window
def show_simple_window():
    global simple_window  # To prevent the window from being garbage collected
    simple_window = SimpleWindow()
    simple_window.show()

def run():
	show_simple_window()

show_simple_window()
