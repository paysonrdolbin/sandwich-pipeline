{
  "rules": [
    {
      "category": "render",
      "path_regexes": ["(^|/)renders?(/|$)"]
    },
    {
      "category": "fx_cache",
      "path_regexes": ["(^|/)fx(/|$)"],
      "suffixes": [".vdb", ".bgeo", ".bgeo.sc", ".sim"]
    },
    {
      "category": "texture",
      "path_regexes": ["(^|/)tex(?:ture)?s?(/|$)"],
      "suffixes": [
        ".tex",
        ".tx",
        ".rat",
        ".png",
        ".jpg",
        ".jpeg",
        ".tif",
        ".tiff",
        ".exr"
      ]
    },
    {
      "category": "publish",
      "path_regexes": ["(^|/)publish(/|$)"]
    },
    {
      "category": "playblast",
      "path_regexes": ["(^|/)playblasts?(/|$)"],
      "suffixes": [".mov", ".mp4"]
    }
  ]
}
