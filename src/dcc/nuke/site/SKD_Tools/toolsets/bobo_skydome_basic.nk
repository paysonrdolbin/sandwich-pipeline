set cut_paste_input [stack 0]
version 15.0 v4
Read {
 inputs 0
 file_type hdr
 file /groups/sandwich/lighting/HDRs/G_HDR_1.exr
 format "4096 2048 0 0 4096 2048 1 4K_LatLong"
 origset true
 name Read2
 selected true
 xpos 5100
 ypos -5826
}
Group {
 name SB_Skydome1
 selected true
 xpos 5019
 ypos -5670
 addUserKnob {20 User}
 addUserKnob {26 text l "Skydome Transformations"}
 addUserKnob {41 translate l Translate T Sphere1.translate}
 addUserKnob {41 rotate l Rotate T Sphere1.rotate}
 addUserKnob {41 uniform_scale l "Uniform Scale" T Sphere1.uniform_scale}
 addUserKnob {26 ""}
 addUserKnob {26 text_1 l "" +STARTLINE T "\n\n(Instructions for Merging)\nif the merge node's B pipe is plugged into this skydome node:\n\n-Set \"metadata from\" to 'A'\n-Set \"frame range from\" to 'A' \n-Set \"Also Merge\" to 'all'\n"}
}
 Input {
  inputs 0
  name Camera
  xpos 509
  ypos -182
  number 1
 }
 Input {
  inputs 0
  name Map
  xpos 375
  ypos -318
 }
 Sphere {
  radius 10000
  name Sphere1
  selected true
  xpos 375
  ypos -256
 }
push 0
 ScanlineRender {
  inputs 3
  conservative_shader_sampling false
  motion_vectors_type distance
  name ScanlineRender1
  xpos 375
  ypos -182
 }
 Output {
  name Output1
  xpos 375
  ypos -104
 }
 Output {
  name Output2
  xpos 375
  ypos -4
 }
end_group
